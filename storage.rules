rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User avatar / profile assets — only the owning user may write.
    match /users/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat media (images, videos, documents) — any authenticated user
    // may upload and download.  The chatId is a sorted pair of real UIDs
    // so it cannot be guessed; authentication is the primary gate here.
    match /chats/{chatId}/files/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

  }
}
