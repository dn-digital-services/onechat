rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- User profiles ----
    // Any authenticated user may READ any profile -- this is required so a
    // user can search another person by phone number and so a chat partner's
    // name/photo/online-status/last-seen can be shown. A profile can only
    // ever be WRITTEN by its own owner.
    match /users/{userId} {

      // "get" (fetch one known doc, e.g. watching a chat partner's profile)
      // is open to any signed-in user. "list" (queries, e.g. phone search) is
      // capped to limit(1) so no one can enumerate/dump the whole user base --
      // only a targeted "does this exact phone number exist" lookup works.
      allow get: if request.auth != null;
      allow list: if request.auth != null && request.query.limit <= 1;

      allow write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

    }

    // ---- One-to-one chats ----
    // chatId is always "<uidA>_<uidB>" with the two uids sorted
    // lexicographically, so a chat is identifiable by its participants alone.
    // Only the two participants may ever read or write it.
    match /chats/{chatId} {

      allow read: if request.auth != null && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {

        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // After creation, only the "status" field may ever change (sent ->
        // delivered -> seen), and only by one of the chat's two participants.
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      }

    }

  }
}
